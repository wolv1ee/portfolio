---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section id="hero">
  <div class="hero-left">
    <h1>
      Building <em>secure</em>
      digital experiences<span class="dots"><span>.</span><span>.</span><span>.</span></span>
    </h1>
    <p class="hero-sub">
      Developer & cybersecurity enthusiast. <br />
     Computer Information Systems at Western Michigan University.<br />
      <span style="color:var(--text);">IT Technician · Web Development · Systems Enthusiast.</span>
    </p>
    <div class="hero-cta">
      <a href="/projects" class="btn btn-primary">View Projects →</a>
      <a href="/contact" class="btn btn-ghost">Get in Touch</a>
    </div>
  </div>

  <div class="terminal-col">
    <div class="terminal">
      <div class="terminal-bar">
        <span class="t-dot" style="background:#ff5f57"></span>
        <span class="t-dot" style="background:#febc2e"></span>
        <span class="t-dot" style="background:#28c840"></span>
        <span class="t-title">saad@portfolio ~ </span>
      </div>
      <div class="terminal-body" id="termBody">
        <div class="t-line"><span class="t-prompt">$ </span><span class="t-cmd">whoami</span></div>
        <div class="t-line t-output">saad - developer & security enthusiast</div>
        <div class="t-line"><span class="t-prompt">$ </span><span class="t-cmd">status</span></div>
        <div class="t-line t-output">open to internships</div>
        <div class="t-line"><span class="t-prompt">$ </span><span class="t-cmd">type 'help' for commands_</span></div>
      </div>
      <div class="terminal-input-row">
        <span class="t-prompt">$ </span>
        <input type="text" id="termInput" placeholder="type a command..." autocomplete="off" spellcheck="false" />
      </div>
    </div>
    <div class="terminal-links">
      <a href="https://github.com/wolv1ee" target="_blank" class="terminal-link">
        <span class="t-link-icon">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </span>
        GitHub ↗
      </a>
      <a href="https://linkedin.com/in/saad-mahmud-" target="_blank" class="terminal-link">
        <span class="t-link-icon">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </span>
        LinkedIn ↗
      </a>
    </div>
    </div>
</section>

  <!-- ══════════════════════════════════════════
       ABOUT TEASER
  ══════════════════════════════════════════ -->
  <section id="about" class="section" style="padding-top: 3rem;">
    <div class="section-label">About me</div>
    <div class="about-grid">

      <div class="reveal">
        <div class="about-img-wrap">
          <img src="/images/saad.webp" alt="Saad Mahmud" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
        </div>
      </div>

      <div class="about-text reveal reveal-delay-1">
        <h2><em>Developer.</em><br />Security-minded.</h2>

        <p>
          I'm studying CIS & Cybersecurity at Western Michigan University, 
          with hands-on experience as an IT Technician at WMU's College of Arts and Science Technology Services,
          Outside of Academics, I'm involved with WRAVEN (OSINT Team), the Developers Club (Systems Team),
          and the Data Science & AI Club (Vice President).
        </p>

        <p>
          I have both technical and administrative experiences which made me adaptable to new challenges and a fast learner.
          Out of work I am a regular gamer, I love playing video games and enjoy playing MMORPG games the most, Currently obsessed with Path of Exile 2!
        </p>

        <div class="skills-list">
          <span class="skill-tag">Python</span>
          <span class="skill-tag">JavaScript</span>
          <span class="skill-tag">React</span>
          <span class="skill-tag">Astro</span>
          <span class="skill-tag">System & Network Admin</span>
          <span class="skill-tag">Linux</span>
          <span class="skill-tag">CSS</span>
          <span class="skill-tag">Active Directory</span>
          <span class="skill-tag">Mosyle</span>
          <span class="skill-tag">Intune</span>
        </div>
      </div>
    </div>
  </section>

<!-- ══════════════════════════════════════════
     CERTIFICATIONS
══════════════════════════════════════════ -->
<section id="certifications" class="section" style="padding-top:0; padding-bottom:2rem;">
  <div class="section-label">Certifications</div>
  <h2>Credentials.</h2>
  <div class="certs-grid reveal">
    <a href="https://www.credly.com/badges/8b55849e-bb8f-41f3-9967-d2d98d60593d/public_url" target="_blank" class="cert-card">
      <img src="/images/isc2-cc.png" alt="ISC2 CC" class="cert-icon-img" />
      <div class="cert-body">
        <div class="cert-name">Certified in Cybersecurity (CC)</div>
        <div class="cert-issuer">ISC2</div>
        <div class="cert-date">2026</div>
      </div>
      <div class="cert-badge">Active</div>
    </a>
  </div>
</section>

<!-- ══════════════════════════════════════════
     EXPERIENCE
══════════════════════════════════════════ -->
<section id="experience" class="section" style="padding-top:0;">
  <div class="section-label">Experience</div>
  <h2>Work History.</h2>
<div class="exp-list reveal">
  <div class="exp-item">
    <div class="exp-left">
      <div class="exp-date">Apr 2026 – Present</div>
      <a href="https://wmich.edu/arts-sciences/technology" target="_blank">
        <img src="/images/WMU.svg" alt="WMU" class="exp-logo" />
      </a>
    </div>
    <div class="exp-right">
      <div class="exp-title">IT Technician</div>
      <div class="exp-company">WMU College of Arts and Science Technology Services</div>
      <ul class="exp-bullets">
        <li>Manage user accounts, permissions, and device policies using Active Directory and Mosyle MDM.</li>
        <li>Resolve hardware, software, printer, and network issues via Salesforce service tickets.</li>
        <li>Support and troubleshoot Windows and macOS systems for faculty, staff, and students.</li>
      </ul>
    </div>
  </div>
  <div class="exp-item">
    <div class="exp-left">
      <div class="exp-date">Apr 2026 – Present</div>
      <a href="https://wmich.edu/career" target="_blank">
        <img src="/images/WMU.svg" alt="WMU" class="exp-logo" />
      </a>
    </div>
    <div class="exp-right">
      <div class="exp-title">Employment Report Assistant</div>
      <div class="exp-company">WMU Career and Employment Services</div>
      <ul class="exp-bullets">
        <li>Analyze student employment data from PeopleSoft, Handshake, and Banner for reporting.</li>
        <li>Build and maintain the Annual Student Employment Report using Excel.</li>
        <li>Process confidential employment verifications via email, MS Teams, and phone.</li>
      </ul>
    </div>
  </div>
  <div class="exp-item">
    <div class="exp-left">
      <div class="exp-date">Apr 2025 – Apr 2026</div>
      <a href="https://wmich.edu/student-center" target="_blank">
        <img src="/images/WMU.svg" alt="WMU" class="exp-logo" />
      </a>
    </div>
    <div class="exp-right">
      <div class="exp-title">Student Facility Manager</div>
      <div class="exp-company">WMU Student Center</div>
      <ul class="exp-bullets">
        <li>Configured and troubleshot 8 high-end gaming PCs for semester-long use.</li>
        <li>Managed AV/IT systems for 50+ campus events annually, reducing event downtime.</li>
        <li>Led help desk student staff to deliver reliable guest support experiences.</li>
      </ul>
    </div>
  </div>
</div>
</section>

  <!-- ══════════════════════════════════════════
       FEATURED PROJECT TEASER
  ══════════════════════════════════════════ -->
  <section id="projects" class="section" style="padding-top:0;">
    <div class="section-label">Featured Work</div>
    <h2>Recent Projects.</h2>
    <p class="section-sub">A few things I made recently.</p>

    <div class="projects-grid reveal">
      <a href="https://github.com/wolv1ee" class="project-card featured reveal" target="_blank">
        <div class="project-content">
          <div class="project-num">01 — Featured</div>
          <h3 class="project-title">Malware Analysis App (In Progress)</h3>
          <p class="project-desc">
            A file security tool that computes the hash of a downloaded file and 
            cross-references it against known malware databases, warning the user 
            if anything suspicious is detected.
          </p>
          <div class="project-tags">
            <span class="project-tag">Python</span>
            <span class="project-tag">React</span>
            <span class="project-tag">FastAPI</span>
            <span class="project-tag">Docker</span>
            <span class="project-tag">hashlib</span>
            <span class="project-tag">VirusTotal API</span>
          </div>
        </div>
        <div class="project-img-wrap">
          <span class="placeholder-text">Loading...</span>
        </div>
        <span class="project-arrow">↗</span>
      </a>
    </div>

    <div style="margin-top:2rem;">
      <a href="/projects" class="btn btn-ghost">All Projects →</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ───────────────────────────────────── */
  #hero {
    min-height: auto;
    display: grid;
    grid-template-columns:1fr 1fr;
    align-items:center;
    padding: 7rem 3rem 0rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }
  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-tag::before {
    content: '';
    width: 32px; height: 1px;
    background: var(--accent);
  }
  .hero-sub {
  font-size: 1.1rem;
  color: var(--text-muted);
  max-width: 480px;
  line-height: 1.8;
  margin-bottom: 3rem;
  }
  .hero-sub strong { color: var(--text); font-weight: 500; }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-scroll {
    position: absolute;
    bottom: 3rem; left: 3rem;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
    letter-spacing: 0.1em;
  }
  .terminal {
    width: 100%;
    background: rgba(13, 13, 13, 0.5);
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    align-self: center;
    margin-top: 1rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    border-radius: 8px;
  }
  .terminal-bar {
    background: rgba(26, 26, 26, 0.6);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 4px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    border-radius: 8px 8px 0 0;
  }
  .t-dot { width: 12px; height: 12px; border-radius: 50%; }
  .t-title {
    margin-left: 8px;
    color: var(--text-faint);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
  }
  .terminal-body {
    padding: 1rem;
    min-height: 350px;
    max-height: 380px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
  }
  .terminal {
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .terminal:hover {
    border-color: var(--accent-border);
    box-shadow: 0 0 20px rgba(232,255,71,0.05);
  }
  .terminal-link {
    transition: all 0.2s;
  }
  .terminal-link:hover {
    border-color: var(--accent-border);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .t-line { color: var(--text-muted); line-height: 1.6; }
  .t-prompt { color: var(--accent); margin-right: 6px; }
  .t-cmd { color: var(--text); }
  .t-output { color: var(--text-muted); padding-left: 1rem; }
  .terminal-input-row {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(13, 13, 13, 0.4);
    backdrop-filter: blur(12px);
    border-radius: 0 0 8px 8px;
  }
  .terminal-input-row input {
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    outline: none;
    flex: 1;
    caret-color: var(--accent);
  }
  .terminal-input-row input::placeholder { color: var(--text-faint); }
  .scroll-line {
    width: 48px; height: 1px;
    background: var(--text-faint);
    position: relative;
    overflow: hidden;
  }
  .terminal-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  .terminal-link {
    width: 100%;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    padding: 0.85rem 2rem;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  .terminal-link:hover {
    border-color: rgba(232, 255, 71, 0.4);
    color: var(--accent);
    background: rgba(232, 255, 71, 0.1);
    box-shadow: 0 12px 48px rgba(232, 255, 71, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: var(--accent);
    animation: scrollLine 2s ease-in-out infinite;
  }
  .dots span {
    animation: blink 1.2s infinite;
    opacity: 0;
  }
  .dots span:nth-child(1) { animation-delay: 0s; }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: pulse 2s ease-in-out infinite;
    writing-mode: horizontal-tb;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* ── About ──────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0rem;
    align-items: start;
  }
  .about-img-wrap {
    position: relative;
    aspect-ratio: 4/5;
    max-width: 420px;
    background: transparent;
    border: none;
    overflow: hidden;
    border-radius: 0;
  }
  .about-img-placeholder {
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .about-corner {
  position: absolute;
  bottom: 1.5rem; left: 1.5rem;
  background: rgba(232, 255, 71, 0.15);
  color: #ffffff;;
  font-family: var(--font-mono);
  font-size: 1rem;
  letter-spacing: 0.08em;
  padding: 6px 12px;
  font-weight: 600;
  border: 1.5px solid rgba(232, 255, 71, 0.4);
  backdrop-filter: blur(12px);
  box-shadow: 0 4px 16px rgba(232, 255, 71, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  }
  .about-text p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.8;
  }
  .about-text p strong { color: var(--text); font-weight: 500; }
  .about-text { padding-left: 0rem; }
  .skills-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2rem; }

  /* ── Certifications ──────────────────────────── */
  .certs-grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 0;
  }
  .cert-card {
    background: var(--bg2);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: background 0.2s;
    text-decoration: none;
    color: var(--text);
  }
  .cert-icon-img {
  width: 60px;
  height: 60px;
  object-fit: contain;
  align: center;
  background: white;
  border-radius: 7px;
  padding: 3px;
}
  .cert-card:hover { background: var(--bg3); }
  .cert-icon {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent);
    width: 40px;
    text-align: center;
  }
  .cert-body { flex: 1; }
  .cert-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--text);
    font-weight: 600;
  }
  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    margin-top: 2px;
  }
  .cert-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-top: 2px;
  }
  .cert-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 4px 12px;
    border: 1px solid var(--accent-border);
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  /* ── Experience ──────────────────────────────── */
  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 2rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }
  .exp-item:hover { background: var(--bg2); }
  .exp-item:last-child { border-bottom: none; }
  .exp-item:first-child { border-radius: 12px 12px 0 0; }
  .exp-item:last-child { border-radius: 0 0 12px 12px; }
  .exp-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    letter-spacing: 0.05em;
    padding-top: 4px;
  }
  .exp-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 200px;
  }
  .exp-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .exp-company {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 0.03em;
  }
  .exp-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .exp-bullets li {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
  }
  .exp-bullets li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.75rem;
  }
  .exp-logo {
    width: 120px;
    height: 120px;
    object-fit: contain;
    display: block;
  }

  /* ── Projects ───────────────────────────────── */
  .projects-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5px; }
  .project-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
    text-decoration: none;
    display: block;
    color: var(--text);
    border-radius: 12px;
  }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .project-card:hover { border-color: var(--border-hover); }
