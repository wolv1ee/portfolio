---
// src/pages/projects.astro
import Layout from '../layouts/Layout.astro';

// ✏️ EDIT: Add your real projects here.
// Each project needs: num, title, desc, tags (array), href, and optionally image.
const projects = [
{
  title: 'Active Directory Home Lab',
  desc: 'Built a test environment Active Directory lab on Windows Server 2022 from scratch. Covered DC promotion, DNS, DHCP, OUs, GPOs, Kerberos authentication, and security policies including account lockout, complexity requirements, and audit logging.',
  tags: ['Windows Server 2022', 'Active Directory', 'DNS', 'DHCP', 'Kerberos', 'GPO'],
  href: 'https://www.linkedin.com/feed/update/urn:li:activity:7447074994968248321/',
  image: '/images/ActiveD.jpg',
},
  // ✏️ ADD MORE: copy the object above and fill in your details
];
---

<Layout title="Projects">
  <section class="section" style="padding-top: 6rem; padding bottom: 2rem;">
    <div class="section-label">Work</div>
    <h2>All Projects.</h2>
    <p class="section-sub">Things I've built: from cybersecurity tools to web apps.</p>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <a
          href={p.href}
          class={`project-card reveal ${i > 0 ? `reveal-delay-${Math.min(i, 3)}` : ''}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="project-arrow">↗</span>

          {p.image ? (
            <div class="project-img">
              <img src={p.image} alt={p.title} />
            </div>
          ) : (
            <div class="project-img project-img--empty">
              {/* 📸 Add p.image in the array above to show a screenshot */}
              <span>📸</span>
            </div>
          )}

          <div class="project-num">{p.num}</div>
          <h3 class="project-title">{p.title}</h3>
          <p class="project-desc">{p.desc}</p>
          <div class="project-tags">
            {p.tags.map(tag => (
              <span class="project-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 0;
  }
  .project-card {
    display:block;
    background: rgba(255, 255, 255, 0.08);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: var(--text);
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .project-card:hover { 
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(232, 255, 71, 0.35);
    box-shadow: 0 12px 48px rgba(232, 255, 71, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }
  .project-card:hover::before { transform: scaleX(1); }

  .project-img {
    width: 100%;
    max-height: 300px;
    margin-bottom: 1.5rem;
    overflow: hidden;
    background: var(--bg3);
    border: 1px solid var(--border);
    align: center;
  }
  .project-img img { width: 100%; height: 100%; object-fit: cover; }
  .project-img--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-faint);
    font-size: 1.5rem;
  }

  .project-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .project-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    transition: all 0.2s;
  }
  .project-tag:hover {
    background: rgba(232, 255, 71, 0.1);
    border-color: rgba(232, 255, 71, 0.3);
    color: var(--accent
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    padding: 3px 10px;
    background: var(--bg);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .project-arrow {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    font-size: 1.1rem;
    color: var(--text-faint);
    transition: transform 0.3s, color 0.3s;
  }
  .project-card:hover .project-arrow { transform: translate(3px, -3px); color: var(--accent); }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
